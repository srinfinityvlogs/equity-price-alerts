# Copy this file to .env and fill in your real values.
# Never commit .env — it's already in .gitignore.

# Get this from @BotFather on Telegram after creating your bot with /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The Chat ID of the Telegram group where you want alerts sent and commands accepted.
# Add your bot to the group, send /start, then run:
#   curl "https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates"
# and look for "chat":{"id": ...} in the response.
TELEGRAM_CHAT_ID=your_group_chat_id_here
